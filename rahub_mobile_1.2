function Notify(t, txt, d)
    spawn(function() pcall(function() SG:SetCore("SendNotification", {Title = t or "RAHUB", Text = txt or "", Duration = d or 3}) end) end)
end

function SendMsg(msg)
    pcall(function() game.TextChatService.TextChannels.RBXGeneral:SendAsync(msg) end)
    pcall(function() ReplicatedStorage.DefaultChatSystemChatEvents.SayMessageRequest:FireServer(msg, "All") end)
end

local function getChar() return LP.Character end
local function getRoot() local c = getChar() return c and c:FindFirstChild("HumanoidRootPart") end
local function getHum() local c = getChar() return c and c:FindFirstChild("Humanoid") end

local function getRole(p)
    if p == LP then return "YOU" end
    if (p.Backpack and p.Backpack:FindFirstChild("Knife")) or (p.Character and p.Character:FindFirstChild("Knife")) then return "MURDERER" end
    if (p.Backpack and p.Backpack:FindFirstChild("Gun")) or (p.Character and p.Character:FindFirstChild("Gun")) then return "SHERIFF" end
    return "INNOCENT"
end

local function StopLoop(loopRef)
    if loopRef then loopRef:Disconnect() end
    return nil
end

local function CleanAll()
    SpeedLoop = StopLoop(SpeedLoop)
    BhopLoop = StopLoop(BhopLoop)
    FlyLoop = StopLoop(FlyLoop)
    NoclipLoop = StopLoop(NoclipLoop)
    HighJumpLoop = StopLoop(HighJumpLoop)
    InvisLoop = StopLoop(InvisLoop)
    XRayLoop = StopLoop(XRayLoop)
    ItemESPLoop = StopLoop(ItemESPLoop)
    SilentAimLoop = StopLoop(SilentAimLoop)
    AutoShootLoop = StopLoop(AutoShootLoop)
    HitboxLoop = StopLoop(HitboxLoop)
    for _, c in pairs(Conn) do pcall(function() c:Disconnect() end) end
    Conn = {}
    ClearPlayerESP()
    ClearItemESP()
    ClearNameTags()
    ClearDistTags()
    MakeVisible()
    pcall(function() for _, o in ipairs(WS:GetDescendants()) do if o:IsA("BasePart") then o.LocalTransparencyModifier = 0 end end end)
end

-- ==================== ESP ====================
function ClearPlayerESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then local hl = p.Character:FindFirstChild("RAHUB_PlayerESP")
            if hl then hl:Destroy() end
        end
    end
end

function UpdatePlayerESP(player)
    if player == LP then return end
    pcall(function()
        if player.Character then
            local old = player.Character:FindFirstChild("RAHUB_PlayerESP"); if old then old:Destroy() end
            local role = getRole(player)
            local hl = Instance.new("Highlight")
            hl.Name = "RAHUB_PlayerESP"; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.Adornee = player.Character; hl.FillTransparency = 0.4; hl.Parent = player.Character
            if role == "MURDERER" then hl.FillColor = Color3.fromRGB(255, 0, 0); hl.OutlineColor = Color3.fromRGB(255, 255, 0)
            elseif role == "SHERIFF" then hl.FillColor = Color3.fromRGB(0, 120, 255); hl.OutlineColor = Color3.fromRGB(255, 255, 255)
            else hl.FillColor = Color3.fromRGB(0, 255, 100); hl.OutlineColor = Color3.fromRGB(255, 255, 255) end
        end
    end)
end

function UpdateAllESP()
    for _, p in ipairs(Players:GetPlayers()) do UpdatePlayerESP(p) end
end

function ClearItemESP()
    for _, o in ipairs(WS:GetDescendants()) do local hl = o:FindFirstChild("RAHUB_ItemESP"); if hl then hl:Destroy() end end
end

function UpdateItemESP()
    for _, o in ipairs(WS:GetDescendants()) do
        if (o:IsA("Tool") or o.Name:lower():find("coin")) and not o:FindFirstChild("RAHUB_ItemESP") then
            local hl = Instance.new("Highlight"); hl.Name = "RAHUB_ItemESP"; hl.Adornee = o
            hl.FillTransparency = 0.3; hl.OutlineColor = Color3.fromRGB(255, 255, 255); hl.Parent = o
            if o.Name:lower():find("gun") then hl.FillColor = Color3.fromRGB(0, 150, 255)
            elseif o.Name:lower():find("knife") then hl.FillColor = Color3.fromRGB(255, 0, 0)
            elseif o.Name:lower():find("coin") then hl.FillColor = Color3.fromRGB(255, 215, 0)
            else hl.FillColor = Color3.fromRGB(255, 255, 0) end
        end
    end
end

function UpdateNameTags(player)
    if player == LP then return end
    pcall(function()
        if player.Character and player.Character:FindFirstChild("Head") then
            local head = player.Character.Head; local old = head:FindFirstChild("RAHUB_NameTag"); if old then old:Destroy() end
            local role = getRole(player)
            local clr = Color3.fromRGB(0, 255, 100)
            if role == "MURDERER" then clr = Color3.fromRGB(255, 0, 0)
            elseif role == "SHERIFF" then clr = Color3.fromRGB(0, 120, 255) end
            local bg = Instance.new("BillboardGui"); bg.Name = "RAHUB_NameTag"
            bg.Size = UDim2.new(0, 120, 0, 22); bg.StudsOffset = Vector3.new(0, 2.5, 0); bg.AlwaysOnTop = true; bg.Parent = head
            local lbl = Instance.new("TextLabel", bg); lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1
            lbl.Text = player.Name .. " [" .. role .. "]"; lbl.TextColor3 = clr; lbl.TextStrokeTransparency = 0
            lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 11
        end
    end)
end

function UpdateDistanceESP(player)
    if player == LP then return end
    pcall(function()
        if player.Character and player.Character:FindFirstChild("Head") and player.Character:FindFirstChild("HumanoidRootPart") then
            local root = getRoot(); if not root then return end
            local head = player.Character.Head; local old = head:FindFirstChild("RAHUB_DistTag"); if old then old:Destroy() end
            local dist = math.floor((root.Position - player.Character.HumanoidRootPart.Position).Magnitude)
            local bg = Instance.new("BillboardGui"); bg.Name = "RAHUB_DistTag"
            bg.Size = UDim2.new(0, 50, 0, 18); bg.StudsOffset = Vector3.new(0, 1.5, 0); bg.AlwaysOnTop = true; bg.Parent = head
            local lbl = Instance.new("TextLabel", bg); lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1
            lbl.Text = dist .. "m"; lbl.TextColor3 = Color3.fromRGB(255, 255, 255); lbl.Font = Enum.Font.Gotham; lbl.TextSize = 10
        end
    end)
end

function ClearNameTags()
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character and p.Character:FindFirstChild("Head") then local tag = p.Character.Head:FindFirstChild("RAHUB_NameTag"); if tag then tag:Destroy() end end
    end
end

function ClearDistTags()
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character and p.Character:FindFirstChild("Head") then local tag = p.Character.Head:FindFirstChild("RAHUB_DistTag"); if tag then tag:Destroy() end end
    end
end

local function MakeInvisible()
    pcall(function()
        local ch = getChar()
        if ch then for _, p in ipairs(ch:GetDescendants()) do if p:IsA("BasePart") then p.Transparency = 1 end end end
    end)
end

local function MakeVisible()
    pcall(function()
        local ch = getChar()
        if ch then for _, p in ipairs(ch:GetDescendants()) do if p:IsA("BasePart") then p.Transparency = 0 end end end
    end)
end

-- ==================== TP ====================
local function TPLobby()
    local r = getRoot(); if not r then return end
    for _, v in ipairs(WS:GetDescendants()) do
        if v:IsA("SpawnLocation") and v:IsA("BasePart") then r.CFrame = v.CFrame + Vector3.new(0, 5, 0); Notify("TP", "Lobby", 2); return end
    end
    r.CFrame = CFrame.new(0, 20, 0); Notify("TP", "Lobby", 2)
end

local function doTP(cf, name)
    local r = getRoot(); if r then r.CFrame = cf; Notify("TP", name, 2) end
end

-- ==================== SAFE FARM ====================
local function SafeFarm()
    Notify("Farm", "Safe farming...", 2)
    task.spawn(function()
        local collected = 0
        if getChar() then for _, p in ipairs(getChar():GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end end
        for _, o in ipairs(WS:GetDescendants()) do
            if o.Name:lower():find("coin") and o:IsA("BasePart") then
                pcall(function()
                    local r = getRoot()
                    if r then
                        local target = o.Position + Vector3.new(0, 3, 0); local start = r.Position
                        for t = 0, 1, 0.02 do local h = getHum(); if h then h.WalkSpeed = 30 end; r.CFrame = CFrame.new(start:Lerp(target, t)); task.wait(0.05) end
                        task.wait(0.5); firetouchinterest(r, o, 0); firetouchinterest(r, o, 1); collected = collected + 1; task.wait(0.3)
                    end
                end)
            end
        end
        if State.SpeedHack then pcall(function() local h = getHum(); if h then h.WalkSpeed = State.SpeedVal or 50 end end)
        else pcall(function() local h = getHum(); if h then h.WalkSpeed = 16 end end) end
        Notify("Farm", "Collected: " .. collected, 3)
    end)
end

local function SafeAutoFarm()
    task.spawn(function()
        while State.AutoFarm do
            pcall(function()
                local r = getRoot(); if not r then return end
                if getChar() then for _, p in ipairs(getChar():GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end end
                for _, o in ipairs(WS:GetDescendants()) do
                    if not State.AutoFarm then break end
                    if o.Name:lower():find("coin") and o:IsA("BasePart") then
                        local target = o.Position + Vector3.new(0, 3, 0); local start = r.Position
                        for t = 0, 1, 0.02 do if getHum() then getHum().WalkSpeed = 30 end; r.CFrame = CFrame.new(start:Lerp(target, t)); task.wait(0.05) end
                        if State.AutoFarm then task.wait(0.5); firetouchinterest(r, o, 0); firetouchinterest(r, o, 1); task.wait(0.3) end; break
                    end
                end
            end)
            task.wait(2)
        end
    end)
end

-- ==================== KILL ALL ====================
local function KillAll()
    local knife = LP.Backpack and LP.Backpack:FindFirstChild("Knife") or (LP.Character and LP.Character:FindFirstChild("Knife"))
    if not knife then Notify("Error", "Need knife!", 3); return end
    local killed = 0
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hum = p.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                pcall(function()
                    local r = getRoot()
                    if r then r.CFrame = p.Character.HumanoidRootPart.CFrame - Vector3.new(0, 0, 2); task.wait(0.15)
                        local h = getHum(); if h then h:EquipTool(knife) end; task.wait(0.1)
                        for i = 1, 3 do knife:Activate(); task.wait(0.05) end; killed = killed + 1
                    end
                end)
                task.wait(0.3)
            end
        end
    end
    Notify("KILL", "Killed: " .. killed, 4)
end

