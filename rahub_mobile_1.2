            local f = Instance.new("Frame", sc)
            f.Size = UDim2.new(1, -16, 0, 44); f.Position = UDim2.new(0, 8, 0, y); f.BackgroundColor3 = Color3.fromRGB(32, 32, 42); f.BorderSizePixel = 0
            local l = Instance.new("TextLabel", f)
            l.Size = UDim2.new(1, -16, 0, 16); l.Position = UDim2.new(0, 8, 0, 4); l.BackgroundTransparency = 1
            l.Text = name .. ": " .. default; l.TextColor3 = Color3.fromRGB(255, 255, 255); l.Font = Enum.Font.GothamBold; l.TextSize = 10; l.TextXAlignment = 0
            local bar = Instance.new("Frame", f)
            bar.Size = UDim2.new(1, -16, 0, 5); bar.Position = UDim2.new(0, 8, 0, 24); bar.BackgroundColor3 = Color3.fromRGB(50, 50, 60); bar.BorderSizePixel = 0
            local fill = Instance.new("Frame", bar)
            fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0); fill.BackgroundColor3 = Color3.fromRGB(255, 80, 80); fill.BorderSizePixel = 0
            local dragging = false
            local function upd()
                local mp = UIS:GetMouseLocation(); local bs = bar.AbsolutePosition.X; local bw = bar.AbsoluteSize.X
                local rel = math.clamp((mp.X - bs) / bw, 0, 1); local val = math.floor(min + (max - min) * rel)
                fill.Size = UDim2.new(rel, 0, 1, 0); l.Text = name .. ": " .. val; if callback then callback(val) end
            end
            local db = Instance.new("TextButton", bar)
            db.Size = UDim2.new(1, 0, 1, 0); db.BackgroundTransparency = 1; db.Text = ""
            db.MouseButton1Down:Connect(function() dragging = true; upd() end)
            UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
            UIS.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then upd() end end)
            y = y + 48
        end
        return tab
    end
    
